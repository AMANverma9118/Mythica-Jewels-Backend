# Set these in Render → Environment → Environment Variables
# Then redeploy the backend (Manual Deploy)

DB_URL=mongodb+srv://user:pass@cluster.mongodb.net/dbname
# or MONGODB_URI= (same connection string)

JWT_SECRET=your_long_random_secret
JWT_KEY=your_long_random_secret

PUBLIC_API_URL=https://mythica-jewels-backend.onrender.com
NODE_ENV=production
PORT=10000

RECAPTCHA_SECRET_KEY=your_recaptcha_secret
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
